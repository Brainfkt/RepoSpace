# Public, frontend-safe configuration. The Git remote currently belongs to Brainfkt.
VITE_GITHUB_USERNAME=Brainfkt

# Public GitHub requests work directly from the browser without authentication.
VITE_GITHUB_API_BASE_URL=https://api.github.com

# Never add a VITE_GITHUB_TOKEN variable. Vite exposes VITE_* values to browsers.
# If private repositories or higher rate limits are needed later, point
# VITE_GITHUB_API_BASE_URL at a server-side proxy and set GITHUB_TOKEN only in
# that proxy's environment.
